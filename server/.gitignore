# =============================================================
#  server/ — Node.js + Express Backend
#  REST API, WebSocket, Firebase Admin, Stripe, MongoDB
# =============================================================


# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/
.npm/

# ── Build Output ─────────────────────────────────────────────
dist/
build/
out/

# ── Environment Files ─────────────────────────────────────────
# CRITICAL: Real .env files must NEVER be committed.
# Copy .env.example and fill in real values locally.
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Cache ─────────────────────────────────────────────────────
.cache/
.nyc_output/
*.tsbuildinfo

# ── Uploads (user-generated content) ─────────────────────────
uploads/
tmp-uploads/

# ── Testing & Coverage ────────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ── Firebase / Google Cloud Credentials ───────────────────────
# NEVER commit service account JSON files.
# Use environment variables instead — see /server/config/firebase.js
config/firebase-service-account.json
config/firebase-service-account*.json
serviceAccountKey.json
firebase-adminsdk*.json
firebase-service-account*.json
*service-account*.json
*-firebase-adminsdk-*.json
google-credentials.json
google-cloud-*.json

# ── Cryptographic Secrets & Certificates ─────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
*.der
*.csr
*.jks
*.keystore

# ── Stripe ────────────────────────────────────────────────────
.stripe/
stripe-cli/

# ── Databases ─────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# ── Operating System ──────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editors ───────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sw?
*.bak

# ── Temp ──────────────────────────────────────────────────────
tmp/
temp/
*.tmp
