# ============================================================
#  DDS Authentication Platform — Environment Variables Template
#
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
#  SAFE to commit: .env.example (no real secrets here)
# ============================================================


# ============================================================
#  APPLICATION
# ============================================================

# Runtime environment: development | staging | production
NODE_ENV=development

# Port the backend server listens on
PORT=5000

# Base URL of the backend API (used by server internally)
API_BASE_URL=http://localhost:5000


# ============================================================
#  DDS SDK CREDENTIALS
#  Obtain these from the DDS Developer Portal after creating
#  an Application. Never expose DDS_SECRET_KEY client-side.
# ============================================================

DDS_APP_ID=app_replace_with_your_application_id
DDS_PUBLIC_KEY=dds_pk_replace_with_your_public_key
DDS_SECRET_KEY=dds_sk_replace_with_your_secret_key


# ============================================================
#  MONGODB
# ============================================================

# MongoDB connection string — use MongoDB Atlas for all environments.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=



# ============================================================
#  AUTHENTICATION
# ============================================================

# Strong, random secret used to sign JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_chars


# ============================================================
#  STRIPE BILLING
#  Obtain keys from https://dashboard.stripe.com/apikeys
#  Use test keys (sk_test_...) for development.
# ============================================================

# Stripe Secret Key — server-side only. NEVER expose to browser.
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key

# Stripe Publishable Key — safe to expose to frontend.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_publishable_key

# Stripe Webhook Signing Secret — from Stripe CLI or Dashboard.
# Generate locally: stripe listen --forward-to localhost:5000/api/v1/billing/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_signing_secret


# ============================================================
#  FRONTEND (Vite)
#  Variables prefixed with VITE_ are exposed to the browser
#  bundle. Do NOT put secrets in VITE_ variables.
# ============================================================

# API base URL used by the Vite frontend to call the backend
VITE_API_URL=http://localhost:5000


# ============================================================
#  FIREBASE — Admin SDK Credentials
#
#  NEVER commit firebase-service-account.json or any JSON key
#  file to version control. Use one of the options below.
#
#  Option A: Individual fields (recommended for local dev)
# ============================================================

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key value. Escape newlines as \n in a single line.
FIREBASE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----


# Option B: Paste the full service account JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}


# Option C: Base64-encoded JSON — best for production & CI/CD pipelines
# Generate the value locally (run outside the repo, not committed):
#   node -e "const fs=require('fs'); console.log(Buffer.from(fs.readFileSync('firebase-service-account.json')).toString('base64'))"
# Then set:
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6...
