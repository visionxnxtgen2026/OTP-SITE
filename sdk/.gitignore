# =============================================================
#  sdk/ — @dds/server Node.js SDK Package
#  Published to npm. Consumers install this package.
# =============================================================


# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build Output ─────────────────────────────────────────────
# dist/ is the published artifact — only ignore locally if
# you build before publish. Un-comment if you commit dist/.
dist/
build/
out/

# ── Environment Files ─────────────────────────────────────────
.env
.env.local
.env.*
!.env.example

# ── Cache & Tool Artifacts ────────────────────────────────────
.cache/
.eslintcache
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Testing & Coverage ────────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ── npm publish helper files (keep these out of source) ───────
.npmrc
# .npmignore controls what goes into the npm tarball — keep committed

# ── Firebase / Google Credentials ─────────────────────────────
serviceAccountKey.json
firebase-adminsdk*.json
firebase-service-account*.json
*service-account*.json
google-credentials.json

# ── Cryptographic Secrets ─────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Operating System ──────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editors ───────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sw?

# ── Temp ──────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
